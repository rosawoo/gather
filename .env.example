# Database (SQLite path relative to prisma folder)
# Resolved relative to the prisma/ folder
DATABASE_URL="file:./dev.db"

# Auth.js — https://authjs.dev/getting-started/installation
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (required for sign-in — empty values cause Error 400 invalid_request)
# 1. https://console.cloud.google.com/apis/credentials
# 2. Create OAuth client ID → Application type: Web application
# 3. Authorized JavaScript origins (add BOTH — Cursor often breaks localhost:3000):
#    http://127.0.0.1:3001
#    http://localhost:3001
# 4. Authorized redirect URIs:
#    http://127.0.0.1:3001/api/auth/callback/google
#    http://localhost:3001/api/auth/callback/google
AUTH_GOOGLE_ID="your-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-client-secret"
# Optional aliases (same values):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# App URL (local)
AUTH_TRUST_HOST=true
# Canonical site URL for OAuth. REQUIRED if you ever open the app as http://192.168.x.x:3001
# — Google blocks private-IP redirects ("device_id and device_name are required for private IP").
# Set this to localhost and use http://localhost:3001 in the browser (same machine as dev server).
AUTH_URL=http://localhost:3001

# Local dev: run `npm run dev`, wait for "Ready", then open http://localhost:3001
# (or http://127.0.0.1:3001). Error -102 / connection refused = dev server not running
# or wrong port. Avoid http://localhost:3000 while Cursor uses that port (empty response).

# Twilio SMS (phone verification + transactional texts)
# https://www.twilio.com/docs — trial accounts can only SMS verified numbers.
# Use EITHER TWILIO_FROM_NUMBER OR TWILIO_MESSAGING_SERVICE_SID (not both required).
# Inbound STOP/START: set webhook on your Twilio number to POST /api/twilio/sms
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164, e.g. +15551234567
TWILIO_FROM_NUMBER=
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx

# Cron: POST /api/cron/auto-cancel with Authorization: Bearer <secret>
CRON_SECRET=

# Optional: Stripe (Phase 4+)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
