# Database (SQLite path relative to prisma folder)
# Resolved relative to the prisma/ folder
DATABASE_URL="file:./dev.db"

# Auth.js — https://authjs.dev/getting-started/installation
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (required for sign-in — empty values cause Error 400 invalid_request)
# 1. https://console.cloud.google.com/apis/credentials
# 2. Create OAuth client ID → Application type: Web application
# 3. Authorized JavaScript origins: http://localhost:3001
# 4. Authorized redirect URIs: http://localhost:3001/api/auth/callback/google
AUTH_GOOGLE_ID="your-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-client-secret"
# Optional aliases (same values):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# App URL (local)
AUTH_TRUST_HOST=true
# Dev server uses 3001 by default so it does not clash with Cursor on port 3000.
# Google OAuth redirect: http://localhost:3001/api/auth/callback/google

# Optional: Twilio for SMS (Phase 2+)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Optional: Stripe (Phase 4+)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
