# --- Vercel production (avoid “Server error / server configuration” on sign-in) ---
# Required in Project → Settings → Environment Variables (Production + Preview):
#   AUTH_SECRET: openssl rand -base64 32  (Auth.js refuses to run without this)
#   AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET: same as local; Google Console → redirect:
#       https://YOUR_DOMAIN/api/auth/callback/google
#   DATABASE_URL: Neon / Postgres connection string
# Strongly recommended:
#   AUTH_URL: https://YOUR_PRODUCTION_DOMAIN  (canonical URL for OAuth)
#   AUTH_TRUST_HOST=true is fine; Vercel also sets VERCEL=1
# If the UI still says “server configuration” but AUTH_SECRET is set:
#   - Enable the same variables for Preview (not only Production) if you test on *.vercel.app previews.
#   - Set AUTH_DEBUG=1, redeploy, check Function logs; DB errors during OAuth also surface as Configuration.
#   - Ensure AUTH_URL matches the URL users open (https, correct host).
# Database (Postgres on Neon / Vercel is recommended)
# Production: connect Neon via the Vercel Storage tab; it sets DATABASE_URL
# automatically. Locally, run `vercel env pull .env.local` to fetch the same
# URL, or point at any Postgres instance.
# Example: DATABASE_URL="postgres://user:pass@host/db?sslmode=require"
DATABASE_URL=

# Auth.js: https://authjs.dev/getting-started/installation
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Temporary: verbose Auth.js + Prisma-related logs on the auth routes (remove after debugging).
# AUTH_DEBUG=1


# Google OAuth (required for sign-in; empty values cause Error 400 invalid_request)
# 1. https://console.cloud.google.com/apis/credentials
# 2. Create OAuth client ID → Application type: Web application
# 3. Authorized JavaScript origins (add BOTH; Cursor often breaks localhost:3000):
#    http://127.0.0.1:3001
#    http://localhost:3001
# 4. Authorized redirect URIs:
#    http://127.0.0.1:3001/api/auth/callback/google
#    http://localhost:3001/api/auth/callback/google
AUTH_GOOGLE_ID="your-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-client-secret"
# Optional aliases (same values):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# App URL (local)
AUTH_TRUST_HOST=true
# Canonical site URL for OAuth. REQUIRED if you ever open the app as http://192.168.x.x:3001
# Note: Google blocks private-IP redirects ("device_id and device_name are required for private IP").
# Set this to localhost and use http://localhost:3001 in the browser (same machine as dev server).
AUTH_URL=http://localhost:3001

# Local dev: run `npm run dev`, wait for "Ready", then open http://localhost:3001
# (or http://127.0.0.1:3001). Error -102 / connection refused = dev server not running
# or wrong port. Avoid http://localhost:3000 while Cursor uses that port (empty response).

# Twilio SMS (phone verification + transactional texts)
# https://www.twilio.com/docs (trial accounts can only SMS verified numbers).
# Use EITHER TWILIO_FROM_NUMBER OR TWILIO_MESSAGING_SERVICE_SID (not both required).
# Inbound STOP/START: set webhook on your Twilio number to POST /api/twilio/sms
# Optional: scripts/send-test-notification.js must differ from TWILIO_FROM_NUMBER
# TWILIO_TEST_TO=+15551234567
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164, e.g. +15551234567
TWILIO_FROM_NUMBER=
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx

# Cron: send Authorization: Bearer <secret> (same CRON_SECRET for both routes):
#   POST /api/cron/auto-cancel: daily min-size check
#   POST /api/cron/event-reminders: within-24h reminders (daily on Vercel Hobby; Pro can use hourly in vercel.json)
CRON_SECRET=

# Vercel Blob: required for profile photo uploads
# Enable in the Vercel Storage tab; it auto-sets BLOB_READ_WRITE_TOKEN on
# deployment. Locally, `vercel env pull` to fetch.
BLOB_READ_WRITE_TOKEN=

# Stripe: token packs on /profile/tokens (Checkout Session + webhook)
# 1) API keys: https://dashboard.stripe.com/apikeys (sk_test… for local dev)
STRIPE_SECRET_KEY=
#
# Customer Portal (Settings → Billing → Customer portal): enable it so
# /profile/settings can open “Manage billing” for users with a Stripe customer id.
# Default products/shortcuts are fine for payment-method updates; no extra env vars.
#
# 2) Webhook signing secret for POST /api/stripe/webhook
#    Local dev: Stripe CLI forwards events (install CLI, then run):
#      stripe listen --forward-to localhost:3001/api/stripe/webhook
#    Paste the printed "whsec_…" secret here.
#    Production: Stripe Dashboard → Developers → Webhooks → add endpoint URL
#    https://<your-domain>/api/stripe/webhook, then select checkout.session.completed
STRIPE_WEBHOOK_SECRET=
#
# Checkout success/cancel URLs use AUTH_URL, or VERCEL_URL on Vercel if AUTH_URL is unset.
