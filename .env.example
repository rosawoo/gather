# Database (SQLite path relative to prisma folder)
# Resolved relative to the prisma/ folder
DATABASE_URL="file:./dev.db"

# Auth.js — https://authjs.dev/getting-started/installation
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# App URL (local)
AUTH_TRUST_HOST=true
# Dev server uses 3001 by default so it does not clash with Cursor on port 3000.
# Google OAuth redirect: http://localhost:3001/api/auth/callback/google

# Optional: Twilio for SMS (Phase 2+)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Optional: Stripe (Phase 4+)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
